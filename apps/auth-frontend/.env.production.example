# Production environment variables for Vercel
# Copy these to your Vercel project settings

# JWT secret — must exactly match JWT_SECRET in the Spring Boot auth-service
# Set this as a secret env var in your hosting platform (never commit the real value)
JWT_SECRET=

# Auth API URL (your backend - update when deployed)
NEXT_PUBLIC_AUTH_API_URL=https://api.volteryde.org/api/auth

# Redirect URLs after login
NEXT_PUBLIC_ADMIN_URL=https://admin.volteryde.org
NEXT_PUBLIC_PARTNERS_URL=https://partners.volteryde.org
NEXT_PUBLIC_SUPPORT_URL=https://support.volteryde.org
NEXT_PUBLIC_DISPATCH_URL=https://dispatch.volteryde.org
